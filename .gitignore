# OS / editor cruft
.DS_Store
Thumbs.db
*.swp
*.swo
*~
.idea/
.vscode/

# Python
__pycache__/
*.pyc
*.pyo
*.pyd

# Logs
*.log
/tmp/

# Test outputs
render_test/# Exclude PNG binaries from site/ (they duplicate chapters/*/diseases/* already in git)
# Build site/ fresh from chapters/ using scripts/site/build_site.py
site/**/*.png
site/**/*.jpg
site/**/*.jpeg
site/**/*.webp

# Build artifacts in chapters/ (generated from .md, not source of truth)
chapters/**/topic.html
chapters/**/topic.png

# Allow HTML and small config files
!site/index.html
!site/README.md
!site/.gitkeep
site/assets/mermaid.min.js
